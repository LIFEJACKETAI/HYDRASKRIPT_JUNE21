prisma:query SELECT "public"."jobs"."id", "public"."jobs"."bookId", "public"."jobs"."ownerId", "public"."jobs"."jobType", "public"."jobs"."status", "public"."jobs"."progressMessage", "public"."jobs"."progressPercent", "public"."jobs"."creditsReserved", "public"."jobs"."creditsConsumed", "public"."jobs"."errorMessage", "public"."jobs"."stepIndex", "public"."jobs"."result", "public"."jobs"."startedAt", "public"."jobs"."completedAt", "public"."jobs"."createdAt" FROM "public"."jobs" WHERE "public"."jobs"."status" = $1 ORDER BY "public"."jobs"."createdAt" ASC LIMIT $2 OFFSET $3
prisma:query COMMIT
